    <exclude body1="left_gripper_base" body2="left_grip_left_spring_link"/>
    <exclude body1="left_gripper_base" body2="left_grip_right_spring_link"/>
    <exclude body1="left_grip_right_coupler" body2="left_grip_right_follower"/>
    <exclude body1="left_grip_left_coupler" body2="left_grip_left_follower"/>
    <!-- Right gripper -->
    <exclude body1="right_gripper_base" body2="right_grip_left_driver"/>
    <exclude body1="right_gripper_base" body2="right_grip_right_driver"/>
    <exclude body1="right_gripper_base" body2="right_grip_left_spring_link"/>
    <exclude body1="right_gripper_base" body2="right_grip_right_spring_link"/>
    <exclude body1="right_grip_right_coupler" body2="right_grip_right_follower"/>
    <exclude body1="right_grip_left_coupler" body2="right_grip_left_follower"/>
  </contact>

  <!-- Gripper tendons: synchronize left and right driver joints -->
  <tendon>
    <fixed name="left_grip_split">
      <joint joint="left_grip_right_driver_joint" coef="0.5"/>
      <joint joint="left_grip_left_driver_joint" coef="0.5"/>
    </fixed>
    <fixed name="right_grip_split">
      <joint joint="right_grip_right_driver_joint" coef="0.5"/>
      <joint joint="right_grip_left_driver_joint" coef="0.5"/>
    </fixed>
  </tendon>

  <!-- Gripper equality constraints: 4-bar linkage + symmetry -->
  <equality>
    <!-- Left gripper -->
    <connect anchor="0 0 0" body1="left_grip_right_follower" body2="left_grip_right_coupler" solimp="0.95 0.99 0.001" solref="0.005 1"/>
    <connect anchor="0 0 0" body1="left_grip_left_follower" body2="left_grip_left_coupler" solimp="0.95 0.99 0.001" solref="0.005 1"/>
    <joint joint1="left_grip_right_driver_joint" joint2="left_grip_left_driver_joint" polycoef="0 1 0 0 0" solimp="0.95 0.99 0.001"
      solref="0.005 1"/>
    <!-- Right gripper -->
    <connect anchor="0 0 0" body1="right_grip_right_follower" body2="right_grip_right_coupler" solimp="0.95 0.99 0.001" solref="0.005 1"/>
    <connect anchor="0 0 0" body1="right_grip_left_follower" body2="right_grip_left_coupler" solimp="0.95 0.99 0.001" solref="0.005 1"/>
    <joint joint1="right_grip_right_driver_joint" joint2="right_grip_left_driver_joint" polycoef="0 1 0 0 0" solimp="0.95 0.99 0.001"
      solref="0.005 1"/>
  </equality>

